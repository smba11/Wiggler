<Window x:Class="WigglerBySmba.TutorialWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding WindowTitle}"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#FFF9F6EF">
    <Border Padding="28" CornerRadius="26" Background="#FFF9F6EF">
        <Grid Width="520">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock FontSize="14" Foreground="#FF6B7280" Text="{Binding BrandText}" />
                <TextBlock Margin="0,8,0,0" FontSize="30" FontWeight="SemiBold" Foreground="#FF1F2937" Text="{Binding TitleText}" />
            </StackPanel>

            <StackPanel Grid.Row="1" Margin="0,24,0,24">
                <TextBlock FontSize="17" TextWrapping="Wrap" Foreground="#FF374151" Text="{Binding BodyText}" />
                <Border Margin="0,20,0,0" Padding="18" Background="White" CornerRadius="20">
                    <TextBlock FontSize="14" TextWrapping="Wrap" Foreground="#FF6B7280" Text="{Binding DetailText}" />
                </Border>
            </StackPanel>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock VerticalAlignment="Center" FontSize="13" Foreground="#FF6B7280" Text="{Binding ProgressText}" />

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Width="96" Height="42" Margin="0,0,10,0" Click="Back_Click" Content="{Binding BackButtonText}" />
                    <Button Width="110" Height="42" Click="Next_Click" Content="{Binding NextButtonText}" />
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
