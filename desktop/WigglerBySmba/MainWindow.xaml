<Window x:Class="WigglerBySmba.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="WIGGLER by SMBA"
        MinHeight="680"
        MinWidth="980"
        Height="760"
        Width="1240"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackgroundBrush}">
    <Window.Resources>
        <Style TargetType="Button" x:Key="SecondaryButtonStyle">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeChipBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="18">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="40" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeChipBorderBrush}" />
            <Setter Property="Padding" Value="6,4" />
        </Style>
        <Style TargetType="Slider">
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
        </Style>
    </Window.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock FontSize="14"
                           Foreground="{DynamicResource SubtleTextBrush}"
                           Text="WIGGLER" />
                <TextBlock Margin="0,6,0,0"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextBrush}"
                           Text="by SMBA" />
            </StackPanel>

            <Border Grid.Column="1"
                    Padding="16,10"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource HeroOutlineBrush}"
                    BorderThickness="1"
                    CornerRadius="18"
                    VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <TextBlock FontSize="12"
                               Foreground="{DynamicResource SubtleTextBrush}"
                               Text="Status" />
                    <TextBlock Margin="8,0,0,0"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource AccentBrush}"
                               Text="{Binding StatusLabel}" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.9*" />
                <ColumnDefinition Width="22" />
                <ColumnDefinition Width="1.1*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{DynamicResource PanelBrush}"
                    BorderBrush="{DynamicResource HeroOutlineBrush}"
                    BorderThickness="1"
                    CornerRadius="34">
                <Grid Margin="26">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Background="{DynamicResource HeroWashBrush}"
                            BorderBrush="{DynamicResource HeroOutlineBrush}"
                            BorderThickness="1"
                            CornerRadius="28"
                            Padding="28">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="250" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource AccentBrush}"
                                           Text="Quiet control for your cursor" />
                                <TextBlock Margin="0,14,0,0"
                                           FontSize="52"
                                           LineHeight="56"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource TextBrush}"
                                           Text="{Binding HeroLabel}" />
                                <TextBlock Margin="0,16,0,0"
                                           FontSize="16"
                                           LineHeight="24"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource SubtleTextBrush}"
                                           Text="{Binding StatusDetail}" />
                            </StackPanel>

                            <Border Grid.Column="1"
                                    Margin="24,0,0,0"
                                    Padding="20"
                                    Background="{DynamicResource HeroCardBrush}"
                                    BorderBrush="{DynamicResource HeroOutlineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="24">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock FontSize="13"
                                               Foreground="{DynamicResource SubtleTextBrush}"
                                               Text="Now tuned for" />
                                    <TextBlock Margin="0,8,0,0"
                                               FontSize="28"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextBrush}"
                                               Text="{Binding SelectedPattern}" />
                                    <TextBlock Margin="0,10,0,0"
                                               FontSize="14"
                                               LineHeight="22"
                                               TextWrapping="Wrap"
                                               Foreground="{DynamicResource SubtleTextBrush}"
                                               Text="Smooth movement, instant interruption, and tighter tray behavior." />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1" Margin="0,22,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock FontSize="14"
                                       Foreground="{DynamicResource SubtleTextBrush}"
                                       Text="Behavior" />
                            <TextBlock Margin="0,8,0,0"
                                       FontSize="28"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextBrush}"
                                       Text="{Binding BehaviorSummary}" />
                            <TextBlock Margin="0,10,0,0"
                                       FontSize="14"
                                       Foreground="{DynamicResource SubtleTextBrush}"
                                       Text="{Binding PatternSummary}" />
                        </StackPanel>

                        <Button Grid.Column="1"
                                Width="176"
                                Height="58"
                                Margin="24,0,0,0"
                                Command="{Binding TogglePowerCommand}"
                                Background="{Binding ToggleButtonBrush}"
                                BorderBrush="{Binding ToggleButtonBrush}"
                                BorderThickness="0"
                                Cursor="Hand"
                                Foreground="{DynamicResource ButtonTextBrush}"
                                FontSize="18"
                                FontWeight="SemiBold">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="20">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                            <TextBlock Text="{Binding ToggleButtonLabel}" />
                        </Button>
                    </Grid>

                    <UniformGrid Grid.Row="2" Margin="0,24,0,0" Columns="3">
                        <Border Margin="0,0,14,0" Padding="18" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource HeroOutlineBrush}" BorderThickness="1" CornerRadius="22">
                            <StackPanel>
                                <TextBlock FontSize="13" Foreground="{DynamicResource SubtleTextBrush}" Text="Idle delay" />
                                <TextBlock Margin="0,10,0,0" FontSize="30" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" Text="{Binding IdleDelayDisplay}" />
                            </StackPanel>
                        </Border>
                        <Border Margin="0,0,14,0" Padding="18" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource HeroOutlineBrush}" BorderThickness="1" CornerRadius="22">
                            <StackPanel>
                                <TextBlock FontSize="13" Foreground="{DynamicResource SubtleTextBrush}" Text="Pattern" />
                                <TextBlock Margin="0,10,0,0" FontSize="30" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" Text="{Binding SelectedPattern}" />
                            </StackPanel>
                        </Border>
                        <Border Padding="18" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource HeroOutlineBrush}" BorderThickness="1" CornerRadius="22">
                            <StackPanel>
                                <TextBlock FontSize="13" Foreground="{DynamicResource SubtleTextBrush}" Text="Takeover" />
                                <TextBlock Margin="0,10,0,0" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" Text="Your mouse wins instantly" />
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <Grid Grid.Row="3" Margin="0,24,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.2*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>

                        <Border Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource HeroOutlineBrush}"
                                BorderThickness="1"
                                CornerRadius="26"
                                Padding="22">
                            <StackPanel>
                                <TextBlock FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}"
                                           Text="How it feels" />
                                <TextBlock Margin="0,14,0,0"
                                           FontSize="14"
                                           LineHeight="22"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource SubtleTextBrush}"
                                           Text="WIGGLER arms first, waits for you to go idle, then traces visible shapes across the screen. The moment you touch the mouse, it stops and hands control back." />
                                <WrapPanel Margin="0,18,0,0">
                                    <Button Width="156"
                                            Height="46"
                                            Margin="0,0,12,12"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Command="{Binding ToggleSettingsCommand}"
                                            Content="{Binding SettingsButtonLabel}" />
                                    <Button Width="156"
                                            Height="46"
                                            Margin="0,0,12,12"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Command="{Binding ReplayTutorialCommand}"
                                            Content="Replay tutorial" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2"
                                Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource HeroOutlineBrush}"
                                BorderThickness="1"
                                CornerRadius="26"
                                Padding="22">
                            <StackPanel>
                                <TextBlock FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}"
                                           Text="Tray-ready" />
                                <TextBlock Margin="0,14,0,0"
                                           FontSize="14"
                                           LineHeight="22"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource SubtleTextBrush}"
                                           Text="Set launch mode to Tray if you want WIGGLER to stay tucked away. Close behavior can either exit completely or minimize to the tray and keep running." />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Background="{DynamicResource SettingsBackgroundBrush}"
                    BorderBrush="{DynamicResource HeroOutlineBrush}"
                    BorderThickness="1"
                    CornerRadius="34">
                <Grid Margin="22">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock FontSize="30"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextBrush}"
                                   Text="Settings" />
                        <TextBlock Margin="0,8,0,0"
                                   FontSize="14"
                                   LineHeight="22"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource SubtleTextBrush}"
                                   Text="Shape the vibe, tray behavior, and movement feel from one place." />
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" Margin="0,18,0,0" VerticalScrollBarVisibility="Auto">
                        <StackPanel Visibility="{Binding IsSettingsOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Border Padding="20" Background="{DynamicResource SettingsPanelBrush}" BorderBrush="{DynamicResource HeroOutlineBrush}" BorderThickness="1" CornerRadius="24">
                                <StackPanel>
                                    <TextBlock FontSize="17" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" Text="Look" />
                                    <TextBlock Margin="0,16,0,8" FontSize="13" Foreground="{DynamicResource SubtleTextBrush}" Text="Mode" />
                                    <ComboBox ItemsSource="{Binding ThemeModeOptions}" SelectedItem="{Binding SelectedThemeMode}" />
                                    <TextBlock Margin="0,16,0,8" FontSize="13" Foreground="{DynamicResource SubtleTextBrush}" Text="Color vibe" />
                                    <ComboBox ItemsSource="{Binding ThemeVibeOptions}" SelectedItem="{Binding SelectedThemeVibe}" />
                                </StackPanel>
                            </Border>

                            <Border Margin="0,16,0,0" Padding="20" Background="{DynamicResource SettingsPanelBrush}" BorderBrush="{DynamicResource HeroOutlineBrush}" BorderThickness="1" CornerRadius="24">
                                <StackPanel>
                                    <TextBlock FontSize="17" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" Text="Behavior" />
                                    <TextBlock Margin="0,16,0,8" FontSize="13" Foreground="{DynamicResource SubtleTextBrush}" Text="Launch in" />
                                    <ComboBox ItemsSource="{Binding LaunchModeOptions}" SelectedItem="{Binding SelectedLaunchMode}" />
                                    <TextBlock Margin="0,16,0,8" FontSize="13" Foreground="{DynamicResource SubtleTextBrush}" Text="Close behavior" />
                                    <ComboBox ItemsSource="{Binding CloseBehaviorOptions}" SelectedItem="{Binding SelectedCloseBehavior}" />
                                    <TextBlock Margin="0,16,0,8" FontSize="13" Foreground="{DynamicResource SubtleTextBrush}" Text="Idle delay" />
                                    <Slider Minimum="5" Maximum="60" TickFrequency="1" IsSnapToTickEnabled="True" Value="{Binding IdleDelaySeconds}" />
                                    <TextBlock Margin="0,6,0,0" FontSize="12" Foreground="{DynamicResource SubtleTextBrush}" Text="{Binding IdleDelayDisplay}" />
                                </StackPanel>
                            </Border>

                            <Border Margin="0,16,0,0" Padding="20" Background="{DynamicResource SettingsPanelBrush}" BorderBrush="{DynamicResource HeroOutlineBrush}" BorderThickness="1" CornerRadius="24">
                                <StackPanel>
                                    <TextBlock FontSize="17" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" Text="Movement" />
                                    <TextBlock Margin="0,16,0,8" FontSize="13" Foreground="{DynamicResource SubtleTextBrush}" Text="Pattern" />
                                    <ComboBox ItemsSource="{Binding PatternOptions}" SelectedItem="{Binding SelectedPattern}" />
                                    <TextBlock Margin="0,16,0,8" FontSize="13" Foreground="{DynamicResource SubtleTextBrush}" Text="Speed" />
                                    <Slider Minimum="0.5" Maximum="3" TickFrequency="0.1" IsSnapToTickEnabled="True" Value="{Binding Speed}" />
                                    <TextBlock Margin="0,6,0,0" FontSize="12" Foreground="{DynamicResource SubtleTextBrush}" Text="{Binding SpeedDisplay}" />
                                    <TextBlock Margin="0,16,0,8" FontSize="13" Foreground="{DynamicResource SubtleTextBrush}" Text="Size" />
                                    <Slider Minimum="40" Maximum="180" TickFrequency="5" IsSnapToTickEnabled="True" Value="{Binding Size}" />
                                    <TextBlock Margin="0,6,0,0" FontSize="12" Foreground="{DynamicResource SubtleTextBrush}" Text="{Binding SizeDisplay}" />
                                </StackPanel>
                            </Border>

                            <Button Margin="0,16,0,0"
                                    Height="48"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding ReplayTutorialCommand}"
                                    Content="Replay tutorial" />
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
