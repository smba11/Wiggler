<Window x:Class="WigglerBySmba.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="WIGGLER by SMBA"
        MinHeight="680"
        MinWidth="980"
        Height="760"
        Width="1240"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackgroundBrush}">
    <Window.Resources>
        <Style TargetType="Button" x:Key="SecondaryButtonStyle">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeChipBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="18">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="52" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeChipBorderBrush}" />
            <Setter Property="Padding" Value="18,6" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="ComboBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="18">
                                <Grid>
                                    <ContentPresenter Margin="18,0,44,0"
                                                      VerticalAlignment="Center"
                                                      Content="{TemplateBinding SelectionBoxItem}" />
                                    <ToggleButton Background="Transparent"
                                                  BorderThickness="0"
                                                  Focusable="False"
                                                  ClickMode="Press"
                                                  IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}" />
                                    <Path Width="10"
                                          Height="6"
                                          Margin="0,0,18,0"
                                          HorizontalAlignment="Right"
                                          VerticalAlignment="Center"
                                          Stroke="{DynamicResource SubtleTextBrush}"
                                          StrokeThickness="2"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          Data="M 0 0 L 5 5 L 10 0" />
                                </Grid>
                            </Border>
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Placement="Bottom"
                                   PlacementTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                   StaysOpen="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   PopupAnimation="Fade">
                                <Border Margin="0,8,0,0"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        Background="{DynamicResource SurfaceBrush}"
                                        BorderBrush="{DynamicResource ThemeChipBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="18">
                                    <ScrollViewer Margin="4"
                                                  CanContentScroll="True"
                                                  VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Margin="2"
                                Background="Transparent"
                                CornerRadius="12">
                            <ContentPresenter Margin="12,0" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource ThemeChipBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource AccentMutedBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Slider">
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
        </Style>
    </Window.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock FontSize="14"
                           Foreground="{DynamicResource SubtleTextBrush}"
                           Text="{Binding BrandTitle}" />
                <TextBlock Margin="0,6,0,0"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextBrush}"
                           Text="{Binding BrandSubtitle}" />
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <Button Width="48"
                        Height="48"
                        Margin="0,0,12,0"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding ToggleSettingsCommand}">
                    <TextBlock FontSize="18"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               Text="⚙" />
                </Button>
                <Border Padding="16,10"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource HeroOutlineBrush}"
                        BorderThickness="1"
                        CornerRadius="18"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontSize="12"
                                   Foreground="{DynamicResource SubtleTextBrush}"
                                   Text="{Binding StatusTitle}" />
                        <TextBlock Margin="8,0,0,0"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AccentBrush}"
                                   Text="{Binding StatusLabel}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <Border
                    Background="{DynamicResource PanelBrush}"
                    BorderBrush="{DynamicResource HeroOutlineBrush}"
                    BorderThickness="1"
                    CornerRadius="34">
                <Grid Margin="26">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Background="{DynamicResource HeroWashBrush}"
                            BorderBrush="{DynamicResource HeroOutlineBrush}"
                            BorderThickness="1"
                            CornerRadius="28"
                            Padding="28">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="250" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource AccentBrush}"
                                           Text="{Binding HeroEyebrow}" />
                                <TextBlock Margin="0,14,0,0"
                                           FontSize="52"
                                           LineHeight="56"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource TextBrush}"
                                           Text="{Binding HeroLabel}" />
                                <TextBlock Margin="0,16,0,0"
                                           FontSize="16"
                                           LineHeight="24"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource SubtleTextBrush}"
                                           Text="{Binding StatusDetail}" />
                            </StackPanel>

                            <Border Grid.Column="1"
                                    Margin="24,0,0,0"
                                    Padding="20"
                                    Background="{DynamicResource HeroCardBrush}"
                                    BorderBrush="{DynamicResource HeroOutlineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="24">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock FontSize="13"
                                               Foreground="{DynamicResource SubtleTextBrush}"
                                               Text="{Binding NowTunedForLabel}" />
                                    <TextBlock Margin="0,8,0,0"
                                               FontSize="28"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextBrush}"
                                               Text="{Binding LocalizedSelectedPattern}" />
                                    <TextBlock Margin="0,10,0,0"
                                               FontSize="14"
                                               LineHeight="22"
                                               TextWrapping="Wrap"
                                               Foreground="{DynamicResource SubtleTextBrush}"
                                               Text="{Binding HeroCardDetail}" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1" Margin="0,22,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock FontSize="14"
                                       Foreground="{DynamicResource SubtleTextBrush}"
                                       Text="{Binding BehaviorTitle}" />
                            <TextBlock Margin="0,8,0,0"
                                       FontSize="28"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextBrush}"
                                       Text="{Binding BehaviorSummary}" />
                            <TextBlock Margin="0,10,0,0"
                                       FontSize="14"
                                       Foreground="{DynamicResource SubtleTextBrush}"
                                       Text="{Binding PatternSummary}" />
                        </StackPanel>

                        <Button Grid.Column="1"
                                Width="176"
                                Height="58"
                                Margin="24,0,0,0"
                                Command="{Binding TogglePowerCommand}"
                                Background="{Binding ToggleButtonBrush}"
                                BorderBrush="{Binding ToggleButtonBrush}"
                                BorderThickness="0"
                                Cursor="Hand"
                                Foreground="{DynamicResource ButtonTextBrush}"
                                FontSize="18"
                                FontWeight="SemiBold">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="20">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                            <TextBlock Text="{Binding ToggleButtonLabel}" />
                        </Button>
                    </Grid>

                    <UniformGrid Grid.Row="2" Margin="0,24,0,0" Columns="3">
                        <Border Margin="0,0,14,0" Padding="18" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource HeroOutlineBrush}" BorderThickness="1" CornerRadius="22">
                            <StackPanel>
                                <TextBlock FontSize="13" Foreground="{DynamicResource SubtleTextBrush}" Text="{Binding IdleDelayCardTitle}" />
                                <TextBlock Margin="0,10,0,0" FontSize="30" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" Text="{Binding IdleDelayDisplay}" />
                            </StackPanel>
                        </Border>
                        <Border Margin="0,0,14,0" Padding="18" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource HeroOutlineBrush}" BorderThickness="1" CornerRadius="22">
                            <StackPanel>
                                <TextBlock FontSize="13" Foreground="{DynamicResource SubtleTextBrush}" Text="{Binding PatternCardTitle}" />
                                <TextBlock Margin="0,10,0,0" FontSize="30" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" Text="{Binding LocalizedSelectedPattern}" />
                            </StackPanel>
                        </Border>
                        <Border Padding="18" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource HeroOutlineBrush}" BorderThickness="1" CornerRadius="22">
                            <StackPanel>
                                <TextBlock FontSize="13" Foreground="{DynamicResource SubtleTextBrush}" Text="{Binding TakeoverTitle}" />
                                <TextBlock Margin="0,10,0,0" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" Text="{Binding TakeoverValue}" />
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <Grid Grid.Row="3" Margin="0,24,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.2*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>

                        <Border Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource HeroOutlineBrush}"
                                BorderThickness="1"
                                CornerRadius="26"
                                Padding="22">
                            <StackPanel>
                                <TextBlock FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}"
                                           Text="{Binding HowItFeelsTitle}" />
                                <TextBlock Margin="0,14,0,0"
                                           FontSize="14"
                                           LineHeight="22"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource SubtleTextBrush}"
                                           Text="{Binding HowItFeelsBody}" />
                                <WrapPanel Margin="0,18,0,0">
                                    <Button Width="156"
                                            Height="46"
                                            Margin="0,0,12,12"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Command="{Binding ToggleSettingsCommand}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Margin="0,0,8,0"
                                                       FontSize="15"
                                                       Text="⚙" />
                                            <TextBlock Text="{Binding SettingsButtonLabel}" />
                                        </StackPanel>
                                    </Button>
                                    <Button Width="156"
                                            Height="46"
                                            Margin="0,0,12,12"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Command="{Binding ReplayTutorialCommand}"
                                            Content="{Binding ReplayTutorialLabel}" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2"
                                Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource HeroOutlineBrush}"
                                BorderThickness="1"
                                CornerRadius="26"
                                Padding="22">
                            <StackPanel>
                                <TextBlock FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}"
                                           Text="{Binding TrayReadyTitle}" />
                                <TextBlock Margin="0,14,0,0"
                                           FontSize="14"
                                           LineHeight="22"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource SubtleTextBrush}"
                                           Text="{Binding TrayReadyBody}" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <Border Width="410"
                    MaxHeight="610"
                    Margin="0,10,10,0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Panel.ZIndex="5"
                    Visibility="{Binding IsSettingsOpen, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Background="{DynamicResource SettingsBackgroundBrush}"
                    BorderBrush="{DynamicResource HeroOutlineBrush}"
                    BorderThickness="1"
                    CornerRadius="34">
                <Grid Margin="22">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Margin="0,0,12,0"
                                       FontSize="24"
                                       VerticalAlignment="Center"
                                       Text="⚙" />
                            <TextBlock FontSize="30"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextBrush}"
                                       Text="{Binding SettingsHeaderTitle}" />
                        </StackPanel>
                        <TextBlock Margin="0,8,0,0"
                                   FontSize="14"
                                   LineHeight="22"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource SubtleTextBrush}"
                                   Text="{Binding SettingsSubtitle}" />
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" Margin="0,18,0,0" VerticalScrollBarVisibility="Auto">
                        <StackPanel Visibility="{Binding IsSettingsOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Border Padding="20" Background="{DynamicResource SettingsPanelBrush}" BorderBrush="{DynamicResource HeroOutlineBrush}" BorderThickness="1" CornerRadius="24">
                                <StackPanel>
                                    <TextBlock FontSize="17" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" Text="{Binding LookSectionTitle}" />
                                    <TextBlock Margin="0,16,0,8" FontSize="13" Foreground="{DynamicResource SubtleTextBrush}" Text="{Binding ThemeLabel}" />
                                    <ComboBox ItemsSource="{Binding ThemeModeItems}"
                                              DisplayMemberPath="Label"
                                              SelectedValuePath="Value"
                                              SelectedValue="{Binding SelectedThemeMode}" />
                                    <TextBlock Margin="0,16,0,8" FontSize="13" Foreground="{DynamicResource SubtleTextBrush}" Text="{Binding ColorVibeLabel}" />
                                    <ComboBox ItemsSource="{Binding ThemeVibeItems}"
                                              DisplayMemberPath="Label"
                                              SelectedValuePath="Value"
                                              SelectedValue="{Binding SelectedThemeVibe}" />
                                    <TextBlock Margin="0,16,0,8" FontSize="13" Foreground="{DynamicResource SubtleTextBrush}" Text="{Binding LanguageLabel}" />
                                    <ComboBox ItemsSource="{Binding LanguageItems}"
                                              DisplayMemberPath="Label"
                                              SelectedValuePath="Value"
                                              SelectedValue="{Binding SelectedLanguageCode}" />
                                </StackPanel>
                            </Border>

                            <Border Margin="0,16,0,0" Padding="20" Background="{DynamicResource SettingsPanelBrush}" BorderBrush="{DynamicResource HeroOutlineBrush}" BorderThickness="1" CornerRadius="24">
                                <StackPanel>
                                    <TextBlock FontSize="17" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" Text="{Binding BehaviorSectionTitle}" />
                                    <TextBlock Margin="0,16,0,8" FontSize="13" Foreground="{DynamicResource SubtleTextBrush}" Text="{Binding LaunchInLabel}" />
                                    <ComboBox ItemsSource="{Binding LaunchModeItems}"
                                              DisplayMemberPath="Label"
                                              SelectedValuePath="Value"
                                              SelectedValue="{Binding SelectedLaunchMode}" />
                                    <TextBlock Margin="0,16,0,8" FontSize="13" Foreground="{DynamicResource SubtleTextBrush}" Text="{Binding CloseBehaviorLabel}" />
                                    <ComboBox ItemsSource="{Binding CloseBehaviorItems}"
                                              DisplayMemberPath="Label"
                                              SelectedValuePath="Value"
                                              SelectedValue="{Binding SelectedCloseBehavior}" />
                                    <TextBlock Margin="0,16,0,8" FontSize="13" Foreground="{DynamicResource SubtleTextBrush}" Text="{Binding IdleDelayLabel}" />
                                    <Slider Minimum="5" Maximum="60" TickFrequency="1" IsSnapToTickEnabled="True" Value="{Binding IdleDelaySeconds}" />
                                    <TextBlock Margin="0,6,0,0" FontSize="12" Foreground="{DynamicResource SubtleTextBrush}" Text="{Binding IdleDelayDisplay}" />
                                </StackPanel>
                            </Border>

                            <Border Margin="0,16,0,0" Padding="20" Background="{DynamicResource SettingsPanelBrush}" BorderBrush="{DynamicResource HeroOutlineBrush}" BorderThickness="1" CornerRadius="24">
                                <StackPanel>
                                    <TextBlock FontSize="17" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" Text="{Binding MovementSectionTitle}" />
                                    <TextBlock Margin="0,16,0,8" FontSize="13" Foreground="{DynamicResource SubtleTextBrush}" Text="{Binding PatternLabel}" />
                                    <ComboBox ItemsSource="{Binding PatternItems}"
                                              DisplayMemberPath="Label"
                                              SelectedValuePath="Value"
                                              SelectedValue="{Binding SelectedPattern}" />
                                    <TextBlock Margin="0,16,0,8" FontSize="13" Foreground="{DynamicResource SubtleTextBrush}" Text="{Binding SpeedLabel}" />
                                    <Slider Minimum="0.5" Maximum="3" TickFrequency="0.1" IsSnapToTickEnabled="True" Value="{Binding Speed}" />
                                    <TextBlock Margin="0,6,0,0" FontSize="12" Foreground="{DynamicResource SubtleTextBrush}" Text="{Binding SpeedDisplay}" />
                                    <TextBlock Margin="0,16,0,8" FontSize="13" Foreground="{DynamicResource SubtleTextBrush}" Text="{Binding SizeLabel}" />
                                    <Slider Minimum="40" Maximum="180" TickFrequency="5" IsSnapToTickEnabled="True" Value="{Binding Size}" />
                                    <TextBlock Margin="0,6,0,0" FontSize="12" Foreground="{DynamicResource SubtleTextBrush}" Text="{Binding SizeDisplay}" />
                                </StackPanel>
                            </Border>

                            <Button Margin="0,16,0,0"
                                    Height="48"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding ReplayTutorialCommand}"
                                    Content="{Binding ReplayTutorialLabel}" />
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
